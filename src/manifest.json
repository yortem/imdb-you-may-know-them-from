{
  "manifest_version": 3,
  "name": "IMDB You May Know Them From",
  "version": "1.0.1",
  "description": "On an actor's IMDB page, shows which movies/shows you've rated that they appear in.",
  "host_permissions": [
    "*://*.imdb.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.imdb.com/name/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/imdb.png",
    "48": "icons/imdb.png",
    "128": "icons/imdb.png"
  }
}
